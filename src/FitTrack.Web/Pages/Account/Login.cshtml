@page
@model FitTrack.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-shell">
<div class="auth-card">
    <p class="eyebrow">Member Access</p>
    <h1>Sign in</h1>
    <p class="page-lead">Sign in with an existing FitTrack member account.</p>

    <form method="post" class="form-stack">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label class="field">
            <span>Email</span>
            <input asp-for="Input.Email" />
            <span asp-validation-for="Input.Email" class="field-validation"></span>
        </label>

        <label class="field">
            <span>Password</span>
            <input asp-for="Input.Password" />
            <span asp-validation-for="Input.Password" class="field-validation"></span>
        </label>

        <button type="submit" class="primary-button">Login</button>
    </form>
</div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
