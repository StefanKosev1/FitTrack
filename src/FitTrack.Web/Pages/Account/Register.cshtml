@page
@model FitTrack.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="card">
    <p class="eyebrow">Join FitTrack</p>
    <h1>Create your account and start training.</h1>
    <p class="page-lead">This starter flow collects the basics for a new member profile. Persistence can be wired in when the database is ready.</p>

    <form method="post" class="form-stack">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label class="field">
            <span>Full Name</span>
            <input asp-for="Input.FullName" />
            <span asp-validation-for="Input.FullName" class="field-validation"></span>
        </label>

        <label class="field">
            <span>Email</span>
            <input asp-for="Input.Email" />
            <span asp-validation-for="Input.Email" class="field-validation"></span>
        </label>

        <label class="field">
            <span>Password</span>
            <input asp-for="Input.Password" />
            <span asp-validation-for="Input.Password" class="field-validation"></span>
        </label>

        <button type="submit" class="primary-button">Create Account</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
