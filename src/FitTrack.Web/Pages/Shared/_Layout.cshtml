<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitTrack</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-backdrop" aria-hidden="true">
        <div class="page-glow page-glow-left"></div>
        <div class="page-glow page-glow-right"></div>
        <div class="page-grid"></div>
    </div>

    <header class="site-header">
        <div class="container nav-shell">
            <a class="brand" asp-page="/Index">
                <span class="brand-mark">FT</span>
                <span class="brand-text">FitTrack</span>
            </a>
            <nav class="nav-links" aria-label="Primary">
                <a asp-page="/Index">Home</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-page="/Dashboard/Index">Dashboard</a>
                    <a asp-page="/Memberships/Index">Membership</a>
                    <span class="nav-identity">@User.Identity.Name</span>
                    <form method="post" asp-page="/Account/Logout">
                        <button type="submit" class="nav-button">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-page="/Account/Login">Login</a>
                    <a asp-page="/Account/Register">Register</a>
                }
            </nav>
        </div>
    </header>

    <div class="container">
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="status-banner" role="status">@statusMessage</div>
        }

        <main class="page-shell">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <span>Strength. Conditioning. Recovery. Memberships that stay simple.</span>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
